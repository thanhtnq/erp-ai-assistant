# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Gemini API ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Chat API security key (X-API-Key header required on all /chat requests) ──
CHAT_API_KEY=change-this-to-a-strong-random-string
AI_API_URL=http://localhost:8001

# ── PostgreSQL (ERP source database) ─────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=your-database-name
PG_USER=postgres
PG_PASSWORD=your-postgres-password

# ── Skills server (Node.js) ───────────────────────────────────────────────────
SKILLS_SERVER_URL=http://localhost:3001

# Scheduled fraud engine. The view must expose the normalized columns documented in README.
FRAUD_TRANSACTION_VIEW=fraud_transaction_source
FRAUD_SCHEDULER_ENABLED=false
FRAUD_SCHEDULER_INTERVAL=daily
FRAUD_SCHEDULER_TIME=01:00
FRAUD_SCHEDULER_DAY=monday
FRAUD_SCHEDULER_SCOPES=[]
FRAUD_AMOUNT_MULTIPLIER=2
FRAUD_FREQUENCY_MULTIPLIER=2
FRAUD_REFUND_MULTIPLIER=3
FRAUD_DISCOUNT_MULTIPLIER=2
FRAUD_VOID_MULTIPLIER=2
FRAUD_INVOICE_MODIFICATIONS=3
FRAUD_BACKDATED_DAYS=7
