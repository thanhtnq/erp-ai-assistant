  "data_transformation": {
    "customer_analysis": {
      "description": "Data for customer analysis",
      "source_tables": ["scm_sal_main", "scm_sal_data"],
      "join_condition": "scm_sal_main.uniquenum_pri = scm_sal_data.uniquenum_pri",
      "output_columns": [
        "customer_id",
        "customer_name",
        "transaction_date",
        "product_code",
        "product_name",
        "category",
        "brand",
        "quantity",
        "unit_price",
        "total_amount",
        "transaction_type"
      ],
      "filters": {
        "tag_void_yn": "n",
        "tag_table_usage": ["sal_soe", "sal_soc", "sal_inv"]
      }
    },
    
    "product_analysis": {
      "description": "Data for product analysis",
      "source_tables": ["scm_sal_data"],
      "output_columns": [
        "product_code",
        "product_name",
        "category",
        "brand",
        "vendor",
        "transaction_date",
        "quantity_sold",
        "revenue",
        "avg_price"
      ],
      "filters": {
        "tag_void_yn": "n"
      }
    },
    
    "sales_trend": {
      "description": "Data for sales trend analysis",
      "source_tables": ["scm_sal_main"],
      "output_columns": [
        "transaction_date",
        "year",
        "month",
        "quarter",
        "day_of_week",
        "business_unit",
        "salesperson",
        "total_transactions",
        "total_revenue",
        "avg_transaction_value"
      ],
      "filters": {
        "tag_void_yn": "n",
        "tag_table_usage": ["sal_inv", "sal_soc"]
      }
    },
    
    "customer_retention": {
      "description": "Data for customer retention analysis",
      "source_tables": ["scm_sal_main"],
      "output_columns": [
        "customer_id",
        "customer_name",
        "first_purchase_date",
        "last_purchase_date",
        "days_since_last_purchase",
        "total_purchases",
        "total_spent",
        "avg_purchase_value",
        "purchase_frequency",
        "customer_lifetime_days"
      ],
      "filters": {
        "tag_void_yn": "n",
        "tag_table_usage": ["sal_inv"]
      }
    }
  },
  
  "feature_engineering": {
    "temporal_features": {
      "year": "EXTRACT(YEAR FROM date_trans)",
      "month": "EXTRACT(MONTH FROM date_trans)",
      "quarter": "EXTRACT(QUARTER FROM date_trans)",
      "day_of_week": "EXTRACT(DOW FROM date_trans)",
      "day_of_month": "EXTRACT(DAY FROM date_trans)",
      "week_of_year": "EXTRACT(WEEK FROM date_trans)",
      "is_weekend": "CASE WHEN EXTRACT(DOW FROM date_trans) IN (0,6) THEN 1 ELSE 0 END",
      "is_month_end": "CASE WHEN EXTRACT(DAY FROM date_trans) >= 25 THEN 1 ELSE 0 END",
      "is_quarter_end": "CASE WHEN EXTRACT(MONTH FROM date_trans) IN (3,6,9,12) AND EXTRACT(DAY FROM date_trans) >= 25 THEN 1 ELSE 0 END"
    },
    
    "customer_features": {
      "recency": "Days since last purchase",
      "frequency": "Number of purchases in period",
      "monetary": "Total amount spent",
      "avg_order_value": "Average order value",
      "unique_products": "Number of unique products purchased",
      "favorite_category": "Most purchased category",
      "favorite_brand": "Most purchased brand"
    },
    
    "product_features": {
      "total_quantity_sold": "Total quantity sold",
      "total_revenue": "Total revenue generated",
      "avg_selling_price": "Average selling price",
      "unique_customers": "Number of unique customers",
      "sales_velocity": "Sales per day",
      "seasonality_index": "Seasonal pattern indicator"
    }
  },
  
  "ml_models": {
    "customer_churn_prediction": {
      "description": "Predict customer churn probability",
      "algorithm": "RandomForestClassifier",
      "features": ["recency", "frequency", "monetary", "avg_order_value", "days_since_last_purchase"],
      "target": "is_churned",
      "threshold_days": 90
    },
    
    "sales_forecast": {
      "description": "Predict sales revenue",
      "algorithm": "Prophet",
      "features": ["date_trans", "amount_local"],
      "target": "future_sales",
      "forecast_horizon": 30
    },
    
    "product_recommendation": {
      "description": "Recommend products to customers",
      "algorithm": "CollaborativeFiltering",
      "features": ["customer_id", "product_code", "quantity"],
      "target": "purchase_probability"
    },
    
    "customer_segmentation": {
      "description": "Segment customers",
      "algorithm": "KMeans",
      "features": ["recency", "frequency", "monetary"],
      "target": "customer_segment",
      "n_clusters": 5
    }
  }
}